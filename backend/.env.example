DATABASE_URL="postgresql://thaical:thaical_dev_pw@localhost:5433/thaical?schema=public"
JWT_SECRET="change-me-in-prod-super-secret-key"
PORT=4000
VISION_PROVIDER=mock

# Optional — only needed when VISION_PROVIDER is set to a real provider
# VISION_PROVIDER=claude        # mock | claude | openai | gemini
#
# Claude (recommended). Default model is claude-opus-4-8; set
# CLAUDE_VISION_MODEL=claude-haiku-4-5 to cut cost for high-volume scanning.
# ANTHROPIC_API_KEY=
# CLAUDE_VISION_MODEL=claude-opus-4-8
#
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
# GEMINI_VISION_MODEL=gemini-1.5-flash
#
# Typhoon (SCB 10X, OpenAI-compatible). Point BASE_URL at the hosted API or a
# local server (Ollama: http://localhost:11434/v1, vLLM: http://localhost:8000/v1).
# TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
# TYPHOON_API_KEY=
# TYPHOON_VISION_MODEL=typhoon2-vision
